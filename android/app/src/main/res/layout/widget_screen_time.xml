<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_screen_time_bg"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Top Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIMIT STATUS"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:textColor="#B0C4CF"/>
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">
                
                <ImageView
                    android:id="@+id/status_icon"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/ic_dialog_alert"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="@null"/>
                
                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EXCEEDED"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFB6B0"/>
            </LinearLayout>
        </LinearLayout>
        
        <TextView
            android:id="@+id/limit_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_pill_bg"
            android:text="LMT 3h 00m"
            android:textColor="#FFB6B0"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"/>
    </RelativeLayout>

    <!-- Huge Time -->
    <TextView
        android:id="@+id/screentime_total"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0h"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFB6B0"
        android:layout_marginTop="4dp"
        android:includeFontPadding="false"/>

    <!-- Progress Bar & Remainder -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="4dp"
            android:layout_marginEnd="8dp">

            <ProgressBar
                android:id="@+id/screentime_progress_white"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:progressDrawable="@drawable/widget_progress_white"
                android:max="100"
                android:progress="0"
                android:visibility="gone"/>

            <ProgressBar
                android:id="@+id/screentime_progress_red"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:progressDrawable="@drawable/widget_progress_red"
                android:max="100"
                android:progress="0"/>
        </FrameLayout>
            
        <TextView
            android:id="@+id/screentime_diff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0m"
            android:textColor="#FFB6B0"
            android:textSize="11sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical" />

    <!-- Selected Apps Card Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_card_bg"
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_marginTop="4dp">

        <!-- Top Header of the Card -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOP APPS"
                    android:textColor="#999999"
                    android:textSize="9sp"
                    android:letterSpacing="0.05"
                    android:textStyle="bold"/>
                    
                <TextView
                    android:id="@+id/screentime_card_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0h"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/screentime_card_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_recent_history"
                android:tint="#FFB6B0"
                android:contentDescription="@null"/>
        </RelativeLayout>

        <!-- Dynamic List -->
        <LinearLayout
            android:id="@+id/screentime_apps_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
            
    </LinearLayout>
</LinearLayout>
