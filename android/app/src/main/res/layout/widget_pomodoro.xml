<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="3dp"
            android:layout_height="12dp"
            android:background="#FF4D6A"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FOCUS"
            android:textColor="#5A7582"
            android:textSize="10sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Main content — fills remaining space, centered -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/pomo_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0m"
            android:textColor="#FFFFFF"
            android:textSize="38sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="focused today"
            android:textColor="#5A7582"
            android:textSize="11sp"/>

        <TextView
            android:id="@+id/pomo_sessions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 sessions"
            android:textColor="#B0C4CF"
            android:textSize="11sp"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

</LinearLayout>
